# Wails build output. Ignore everything under build/ except the source icon,
# the icon scripts, and the committed platform packaging templates (darwin /
# windows / linux). Compiled binaries and the downloaded WebView2 bootstrapper
# stay ignored — they are regenerated on every build.
build/*
!build/appicon.png
!build/icon/
!build/dmg/
!build/darwin/
!build/windows/
!build/linux/
build/bin/
build/windows/installer/tmp/
# Transient render output; the committed deliverable is build/appicon.png.
build/icon/o3-*.png
# Generated by `wails dev` from Info.plist on every run — not source.
build/darwin/Info.dev.plist

node_modules
frontend/dist
.superpowers/
go.work.sum
o3
build/darwin/tools/
